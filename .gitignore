# --- Virtual Environments ---
venv/
.venv/
env/
bin/
lib/
include/

# --- Python Artifacts ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# --- Data and Large Files ---
data/
/tensorflow_datasets/
*.tar.gz
*.zip
*.pickle

# --- Outputs & Logs ---
# Ignore everything under /outputs/ except the small run-summary JSONs that
# back the System Card and threshold-sweep claims. Those need to ride with
# the v1.0-final tag so a grader can inspect them from a fresh clone.
/outputs/*
!/outputs/runs/
/outputs/runs/*
!/outputs/runs/*.json

# --- OS and IDE specific ---
.DS_Store
.vscode/
.idea/
.ipynb_checkpoints/

# --- Environment Secrets ---
.env

# --- Tooling and source materials (not part of the released package) ---
.claude/
CLAUDE.md
Milestone*_Detailed_Guide.pdf