# --- Virtual Environments ---
venv/
.venv/
env/
bin/
lib/
include/

# --- Python Artifacts ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# --- Data and Large Files ---
data/
/tensorflow_datasets/
*.tar.gz
*.zip
*.pickle

# --- Outputs & Logs ---
# Default: ignore everything under outputs/ (bench dumps, embedding caches,
# error-analysis folders) then carve back in the tracked run-convention
# artifacts: per-run JSONs, per-run plot PNGs, and the changelog.
/outputs/*
!/outputs/runs/
/outputs/runs/*
!/outputs/runs/README.md
!/outputs/runs/run_*.json
!/outputs/plots/
/outputs/plots/*
!/outputs/plots/run_*.png

# --- OS and IDE specific ---
.DS_Store
.vscode/
.idea/
.ipynb_checkpoints/

# --- Environment Secrets ---
.env